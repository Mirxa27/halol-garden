{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":pinAllExceptPeerDependencies",
    ":automergeMinor",
    ":automergePatch",
    ":semanticCommits",
    "security:openssf-scorecard"
  ],
  "description": "STRICT PRODUCTION STANDARDS - Automated dependency management",
  
  "schedule": ["before 3am on Monday"],
  "timezone": "UTC",
  
  "labels": ["dependencies", "automated", "renovate"],
  "assignees": ["@team-lead"],
  "reviewers": ["@security-team"],
  
  "packageRules": [
    {
      "description": "Auto-merge patch updates",
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Auto-merge minor updates after tests pass",
      "matchUpdateTypes": ["minor"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true,
      "schedule": ["after 10pm and before 5am"]
    },
    {
      "description": "Require approval for major updates",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["major-update", "requires-review"]
    },
    {
      "description": "Security updates - high priority",
      "matchManagers": ["npm"],
      "matchDepTypes": ["dependencies", "devDependencies"],
      "matchPackagePatterns": ["*"],
      "matchUpdateTypes": ["patch", "minor"],
      "prPriority": 10,
      "automerge": true,
      "minimumReleaseAge": "0 days",
      "matchVulnerabilityAlerts": true
    },
    {
      "description": "Group Radix UI updates",
      "matchPackagePatterns": ["^@radix-ui/"],
      "groupName": "Radix UI",
      "automerge": true
    },
    {
      "description": "Group React ecosystem updates",
      "matchPackageNames": ["react", "react-dom", "@types/react", "@types/react-dom"],
      "groupName": "React",
      "automerge": false
    },
    {
      "description": "Group Next.js updates",
      "matchPackageNames": ["next", "@next/font", "eslint-config-next"],
      "groupName": "Next.js",
      "automerge": false
    },
    {
      "description": "Group testing library updates",
      "matchPackagePatterns": ["^@testing-library/", "^jest", "^vitest"],
      "groupName": "Testing",
      "automerge": true
    },
    {
      "description": "Group linting updates",
      "matchPackagePatterns": ["^eslint", "^@typescript-eslint/"],
      "groupName": "Linting",
      "automerge": true
    },
    {
      "description": "Group type definitions",
      "matchPackagePatterns": ["^@types/"],
      "groupName": "Type Definitions",
      "automerge": true
    },
    {
      "description": "Pin Docker digests",
      "matchManagers": ["dockerfile"],
      "pinDigests": true
    },
    {
      "description": "Update GitHub Actions",
      "matchManagers": ["github-actions"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    }
  ],
  
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "vulnerability"],
    "assignees": ["@security-team"],
    "reviewers": ["@team-lead"],
    "automerge": true,
    "minimumReleaseAge": "0 days"
  },
  
  "prConcurrentLimit": 10,
  "prCreation": "immediate",
  "prHourlyLimit": 2,
  
  "semanticCommits": "enabled",
  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",
  
  "postUpdateOptions": [
    "npmDedupe",
    "yarnDedupeHighest"
  ],
  
  "npm": {
    "minimumReleaseAge": "3 days",
    "stabilityDays": 3,
    "rangeStrategy": "pin",
    "packageRules": [
      {
        "matchDepTypes": ["peerDependencies"],
        "rangeStrategy": "widen"
      }
    ]
  },
  
  "ignoreDeps": [],
  
  "prBodyTemplate": "## 🤖 Automated Dependency Update\n\nThis PR contains the following updates:\n\n{{#if isMajor}}⚠️ **Major Update** - Please review carefully for breaking changes{{/if}}\n{{#if isSingleVersion}}📦 **Single Version Update**{{/if}}\n{{#if isPin}}📌 **Pin Update**{{/if}}\n{{#if isRollback}}⏪ **Rollback**{{/if}}\n\n{{table}}\n\n---\n\n### Release Notes\n\n{{#each upgrades}}\n{{#if releases}}\n<details>\n<summary>{{depName}}</summary>\n\n{{#each releases}}\n{{#if releaseNotes}}\n#### [`v{{version}}`]({{releaseNotes.url}})\n\n{{releaseNotes.body}}\n{{/if}}\n{{/each}}\n</details>\n{{/if}}\n{{/each}}\n\n---\n\n### Configuration\n\n📅 **Schedule**: {{schedule}}\n🚦 **Automerge**: {{#if automerge}}Enabled{{else}}Disabled{{/if}}\n♻ **Rebasing**: {{#if rebaseWhen}}{{rebaseWhen}}{{else}}Whenever PR becomes conflicted{{/if}}\n\n---\n\n### Production Validation Checklist\n\n- [ ] TypeScript compilation successful\n- [ ] ESLint checks passed\n- [ ] Tests passing\n- [ ] Security audit clean\n- [ ] Bundle size acceptable\n- [ ] No breaking changes identified\n- [ ] Manual testing completed (for major updates)\n\n---\n\nThis PR has been generated by [Renovate Bot](https://github.com/renovatebot/renovate).",
  
  "commitMessagePrefix": "chore(deps):",
  "commitMessageAction": "update",
  "commitMessageTopic": "{{depName}}",
  "commitMessageExtra": "to v{{newVersion}}",
  
  "rebaseWhen": "behind-base-branch",
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "🔄 Dependency Dashboard",
  
  "suppressNotifications": ["prIgnoreNotification"],
  
  "transitiveRemediation": true,
  "osvVulnerabilityAlerts": true
}