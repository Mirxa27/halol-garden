# ----------------------------
# Core
NODE_ENV=development
DATABASE_URL="postgresql://user:password@localhost:5432/medical_db"
REDIS_URL="redis://localhost:6379"

# URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000/api"
NEXT_PUBLIC_WS_URL="ws://localhost:3001"

# Authentication
JWT_SECRET="please-change-me-super-secret-jwt"
SESSION_SECRET="please-change-me-session-secret"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="please-change-me-nextauth"

# Email (Nodemailer)
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER="username"
SMTP_PASS="password"
SMTP_FROM="noreply@medical-devices.com"

# Stripe
STRIPE_SECRET_KEY="sk_test_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"

# PayPal
PAYPAL_CLIENT_SECRET="paypal-secret"
NEXT_PUBLIC_PAYPAL_CLIENT_ID="paypal-client-id"

# S3 / Cloudinary (optional)
AWS_ACCESS_KEY_ID="aws-key"
AWS_SECRET_ACCESS_KEY="aws-secret"
AWS_REGION="us-east-1"
S3_BUCKET="medical-assets"
CLOUDINARY_CLOUD_NAME="cloud-name"
CLOUDINARY_API_KEY="api-key"
CLOUDINARY_API_SECRET="api-secret"

# Monitoring & Analytics
NEXT_PUBLIC_SENTRY_DSN="https://example.ingest.sentry.io/12345"
SENTRY_AUTH_TOKEN="sentry-auth-token"
NEXT_PUBLIC_GA_ID="G-XXXXXXXX"

# OpenAI (optional)
OPENAI_API_KEY="sk-xxxxx"

# Notifications
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/..."
NOTIFICATION_EMAIL="admin@medical-devices.com"

# Cron secret (if needed)
CRON_SECRET="cron-secret-token"