# ===================================
# MEDICAL DEVICES MARKETPLACE
# Environment Variables Configuration
# ===================================
# For Vercel deployment: Add these in Dashboard > Settings > Environment Variables
# For local development: Copy to .env.local

# ===================================
# CORE DATABASE (Required)
# ===================================
# PostgreSQL connection string
# Free options: Neon (https://neon.tech), Supabase, or Vercel Postgres
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# ===================================
# CACHING & SESSIONS (Required)
# ===================================
# Redis for caching and session management
# Free option: Upstash Redis (https://upstash.com)
REDIS_URL=redis://default:password@host:6379

# ===================================
# AUTHENTICATION (Required)
# ===================================
# Generate secure secrets with: openssl rand -base64 32
JWT_SECRET=change-this-to-random-32-char-string
JWT_REFRESH_SECRET=change-this-to-another-32-char
SESSION_SECRET=change-this-to-unique-32-char
NEXTAUTH_SECRET=change-this-to-secure-32-char
NEXTAUTH_URL=https://your-app.vercel.app

# ===================================
# EMAIL SERVICE (Required for notifications)
# ===================================
# SMTP Configuration (Gmail, SendGrid, or any SMTP service)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM=noreply@your-domain.com

# ===================================
# PAYMENT GATEWAYS (At least one required)
# ===================================
# Stripe (Recommended for international)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# PayPal
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_client_id
PAYPAL_CLIENT_SECRET=your_client_secret
PAYPAL_MODE=sandbox

# MyFatoorah (Middle East)
NEXT_PUBLIC_MYFATOORAH_API_KEY=your_api_key
MYFATOORAH_API_SECRET=your_api_secret
MYFATOORAH_MODE=test

# ===================================
# FILE STORAGE (Optional)
# ===================================
# Option 1: AWS S3
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
S3_BUCKET=your-bucket-name

# Option 2: Cloudinary (Easier setup)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===================================
# REAL-TIME FEATURES (Optional)
# ===================================
# Pusher for real-time messaging
PUSHER_APP_ID=your_app_id
NEXT_PUBLIC_PUSHER_KEY=your_key
PUSHER_SECRET=your_secret
NEXT_PUBLIC_PUSHER_CLUSTER=us2

# ===================================
# MONITORING & ANALYTICS (Optional)
# ===================================
# Sentry for error tracking
NEXT_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/project
SENTRY_AUTH_TOKEN=your_auth_token

# Google Analytics
NEXT_PUBLIC_GA_ID=G-YOUR_GA_ID

# ===================================
# AI FEATURES (Optional)
# ===================================
OPENAI_API_KEY=sk-your-openai-api-key

# ===================================
# MAPS & LOCATION (Optional)
# ===================================
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key

# ===================================
# NOTIFICATIONS (Optional)
# ===================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK
NOTIFICATION_EMAIL=admin@your-domain.com

# ===================================
# APPLICATION URLs
# ===================================
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_API_URL=https://your-app.vercel.app/api
NEXT_PUBLIC_WS_URL=wss://your-app.vercel.app

# ===================================
# ENVIRONMENT
# ===================================
NODE_ENV=production