# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/medical_devices_db"

# Next.js Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-here"

# Authentication
AUTH_SECRET="your-auth-secret-here"

# Email Configuration (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="Medical Devices Marketplace <noreply@medicaldevices.com>"

# Payment Gateway - Stripe
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# Payment Gateway - PayPal
PAYPAL_CLIENT_ID="your_paypal_client_id"
PAYPAL_CLIENT_SECRET="your_paypal_client_secret"
PAYPAL_MODE="sandbox" # or "live" for production

# Payment Gateway - MyFatoorah (Popular in Middle East)
MYFATOORAH_API_KEY="your_myfatoorah_api_key"
MYFATOORAH_BASE_URL="https://apitest.myfatoorah.com" # or production URL

# Bank Transfer Details
BANK_ACCOUNT_NUMBER="SA03 8000 0000 6080 1016 7519"
BANK_NAME="Al Rajhi Bank"
BANK_SWIFT_CODE="RJHISARI"

# Redis Cache (Optional but recommended)
REDIS_URL="redis://localhost:6379"

# Elasticsearch (Optional for advanced search)
ELASTICSEARCH_URL="http://localhost:9200"

# Cloud Storage (for file uploads)
# AWS S3
AWS_ACCESS_KEY_ID="your_aws_access_key"
AWS_SECRET_ACCESS_KEY="your_aws_secret_key"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="medical-devices-uploads"

# OR use local storage
UPLOAD_DIR="./uploads"

# OpenAI API (for AI features)
OPENAI_API_KEY="sk-your-openai-api-key"

# Monitoring and Analytics
SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"
GOOGLE_ANALYTICS_ID="GA-XXXXXXXXX"
MIXPANEL_TOKEN="your_mixpanel_token"

# Security
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW_MS="900000"
CORS_ORIGINS="http://localhost:3000,https://yourdomain.com"

# Feature Flags
ENABLE_CHAT="true"
ENABLE_AI_RECOMMENDATIONS="true"
ENABLE_ADVANCED_SEARCH="true"

# Localization
DEFAULT_LOCALE="en"
SUPPORTED_LOCALES="en,ar"

# Development
NODE_ENV="development" # production, development, test

# Logging
LOG_LEVEL="info" # debug, info, warn, error

# Session Configuration
SESSION_MAX_AGE="86400" # 24 hours in seconds

# File Upload Limits
MAX_FILE_SIZE="10485760" # 10MB in bytes
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/gif,application/pdf"

# SMS Configuration (Optional)
TWILIO_ACCOUNT_SID="your_twilio_account_sid"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="+1234567890"

# Push Notifications (Optional)
FIREBASE_PROJECT_ID="your-firebase-project"
FIREBASE_PRIVATE_KEY="your-firebase-private-key"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@your-project.iam.gserviceaccount.com"

# Backup Configuration
BACKUP_DATABASE_URL="postgresql://backup_user:password@backup-host:5432/backup_db"
BACKUP_RETENTION_DAYS="30"

# Admin Configuration
ADMIN_EMAIL="admin@medicaldevices.com"
ADMIN_INITIAL_PASSWORD="change_this_in_production"