# PRODUCTION ENVIRONMENT VARIABLES
# Copy this file to .env and fill in all values
# NO DEFAULTS - All values must be explicitly set for production

# Database Configuration (Required)
DATABASE_URL="postgresql://user:password@localhost:5432/medical_devices_prod"
DIRECT_URL="postgresql://user:password@localhost:5432/medical_devices_prod"

# Authentication (Required)
NEXTAUTH_URL="https://yourdomain.com"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
JWT_SECRET="generate-with-openssl-rand-base64-32"

# Application Settings (Required)
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://yourdomain.com"
NEXT_PUBLIC_API_URL="https://api.yourdomain.com"

# Email Service (Required for production)
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT="587"
SMTP_USER="apikey"
SMTP_PASSWORD="your-sendgrid-api-key"
SMTP_FROM="noreply@yourdomain.com"

# Payment Processing (Required if using payments)
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# File Storage (Required for uploads)
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="your-bucket-name"

# Redis Cache (Required for production)
REDIS_URL="redis://localhost:6379"

# Search Engine (Optional but recommended)
ELASTICSEARCH_URL="http://localhost:9200"

# Monitoring and Analytics (Required for production)
SENTRY_DSN="https://...@sentry.io/..."
GOOGLE_ANALYTICS_ID="G-XXXXXXXXXX"
VERCEL_ANALYTICS_ID="your-vercel-analytics-id"

# Security Headers (Required)
CONTENT_SECURITY_POLICY="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline';"
X_FRAME_OPTIONS="DENY"
X_CONTENT_TYPE_OPTIONS="nosniff"
X_XSS_PROTECTION="1; mode=block"
STRICT_TRANSPORT_SECURITY="max-age=31536000; includeSubDomains"

# Rate Limiting (Required)
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX_REQUESTS="100"

# Session Configuration (Required)
SESSION_MAX_AGE="86400"
SESSION_UPDATE_AGE="3600"

# API Keys (As needed)
OPENAI_API_KEY="sk-..."
GOOGLE_MAPS_API_KEY="AIza..."
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_PHONE_NUMBER="+1234567890"

# Feature Flags (Optional)
ENABLE_BETA_FEATURES="false"
ENABLE_DEBUG_MODE="false"
ENABLE_MAINTENANCE_MODE="false"

# Backup Configuration (Required for production)
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS="30"
BACKUP_S3_BUCKET="your-backup-bucket"

# Logging (Required for production)
LOG_LEVEL="info"
LOG_FORMAT="json"
LOG_DESTINATION="stdout"

# Performance Settings
MAX_CONNECTIONS="100"
CONNECTION_TIMEOUT="30000"
REQUEST_TIMEOUT="60000"
BODY_SIZE_LIMIT="10mb"

# Localization
DEFAULT_LOCALE="ar"
SUPPORTED_LOCALES="ar,en"
TIMEZONE="Asia/Riyadh"

# IMPORTANT: Never commit .env file with real values
# Use environment-specific files: .env.local, .env.production
# Store secrets in secure vault (AWS Secrets Manager, HashiCorp Vault, etc.)