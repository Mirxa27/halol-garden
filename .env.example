# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
REDIS_URL=redis://default:password@host:port

# Authentication Secrets (Generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-min-32-characters
JWT_REFRESH_SECRET=your-refresh-secret-min-32-characters
SESSION_SECRET=your-session-secret-min-32-characters
ENV_ENCRYPTION_KEY=your-encryption-key-min-32-characters

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM=Medical Devices <noreply@yourdomain.com>

# Payment - PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox

# Payment - MyFatoorah (Optional)
MYFATOORAH_API_KEY=
MYFATOORAH_BASE_URL=
MYFATOORAH_MODE=test

# Site Configuration
SITE_NAME=Medical Devices Marketplace
SITE_URL=https://your-domain.vercel.app
UPLOAD_DIR=/tmp/uploads
MAX_FILE_SIZE=10485760

# Public Environment Variables (Accessible in Browser)
NEXT_PUBLIC_API_URL=https://your-domain.vercel.app/api
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
NEXT_PUBLIC_SITE_NAME=Medical Devices Marketplace
NEXT_PUBLIC_SUPPORT_EMAIL=support@yourdomain.com

# AI Providers (Optional)
OPENAI_API_KEY=
OPENAI_ORG_ID=
OPENAI_MODEL=gpt-3.5-turbo

GEMINI_API_KEY=
GEMINI_MODEL=gemini-pro

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=

DEEPGRAM_API_KEY=

HUME_API_KEY=
HUME_SECRET_KEY=

# Monitoring (Optional)
SENTRY_DSN=
GOOGLE_ANALYTICS_ID=

# Vercel Integration (Optional - for admin panel)
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# Node Environment
NODE_ENV=production