# ===================================
# MEDICAL DEVICES MARKETPLACE
# Environment Variables Configuration
# ===================================
# Copy this file to .env.local for development
# For production, set these in Vercel Dashboard

# ===================================
# APPLICATION SETTINGS
# ===================================
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_API_URL=https://your-domain.com/api

# ===================================
# DATABASE (PostgreSQL)
# ===================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL=postgresql://user:password@localhost:5432/medical_devices?schema=public

# For Vercel/Neon/Supabase PostgreSQL:
# DATABASE_URL=postgresql://user:password@host.region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# DIRECT_DATABASE_URL=postgresql://user:password@host.region.pooler.supabase.com:5432/postgres

# ===================================
# AUTHENTICATION & SECURITY
# ===================================
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# NextAuth (if using NextAuth.js)
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=your-nextauth-secret-change-in-production

# ===================================
# SUPER ADMIN CREDENTIALS
# ===================================
# Initial super admin account (change after first login!)
SUPER_ADMIN_EMAIL=superadmin@medical-devices.com
SUPER_ADMIN_PASSWORD=SuperAdmin@2024!

# ===================================
# EMAIL CONFIGURATION (SMTP)
# ===================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM=noreply@medical-devices.com

# For Gmail:
# 1. Enable 2FA on your Google account
# 2. Generate app-specific password
# 3. Use that password for SMTP_PASS

# For SendGrid:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key

# ===================================
# PAYMENT GATEWAYS
# ===================================

# Stripe
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# MyFatoorah
MYFATOORAH_API_KEY=your_myfatoorah_api_key
MYFATOORAH_BASE_URL=https://api.myfatoorah.com
# For testing: https://apitest.myfatoorah.com
MYFATOORAH_TEST_MODE=false

# PayPal (Optional)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=production
# For testing: sandbox

# ===================================
# FILE STORAGE
# ===================================

# Local Storage (default)
UPLOAD_DIR=./public/uploads
MAX_FILE_SIZE=10485760

# AWS S3 (Optional)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=medical-devices-uploads

# Cloudinary (Optional)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===================================
# REDIS CACHE (Optional but recommended)
# ===================================
REDIS_URL=redis://localhost:6379
# For Upstash Redis:
# REDIS_URL=redis://default:password@endpoint.upstash.io:port

# ===================================
# REAL-TIME FEATURES (Socket.io)
# ===================================
NEXT_PUBLIC_SOCKET_URL=wss://your-domain.com
SOCKET_IO_PORT=3001

# ===================================
# ANALYTICS & MONITORING
# ===================================

# Vercel Analytics
NEXT_PUBLIC_ANALYTICS_ID=your_vercel_analytics_id

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry Error Tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
NEXT_PUBLIC_SENTRY_DSN=https://your-public-sentry-dsn@sentry.io/project-id

# LogRocket
LOGROCKET_APP_ID=your-org/your-app

# ===================================
# EXTERNAL APIS
# ===================================

# OpenAI (for AI features)
OPENAI_API_KEY=sk-your-openai-api-key

# Google Maps (for location features)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# SMS Gateway (Twilio)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ===================================
# RATE LIMITING
# ===================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ===================================
# SECURITY HEADERS
# ===================================
CSP_DIRECTIVES="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://js.stripe.com; style-src 'self' 'unsafe-inline';"

# ===================================
# LOGGING
# ===================================
LOG_LEVEL=info
LOG_EMAILS=true
LOG_QUERIES=false

# ===================================
# DEVELOPMENT ONLY
# ===================================
# These should only be set in development
ANALYZE_BUNDLE=false
DEBUG_MODE=false

# ===================================
# VERCEL SPECIFIC
# ===================================
# These are automatically set by Vercel
# VERCEL_URL
# VERCEL_ENV
# VERCEL_REGION
# VERCEL_GIT_COMMIT_SHA
# VERCEL_GIT_COMMIT_MESSAGE