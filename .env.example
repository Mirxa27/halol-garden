# ====================================
# Medical Devices Marketplace
# Environment Variables Template
# ====================================

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_WS_URL=ws://localhost:3000
NEXT_PUBLIC_SITE_NAME=Medical Devices Marketplace
NEXT_PUBLIC_SUPPORT_EMAIL=support@medical-devices.com

# Database
DATABASE_URL=postgresql://medical_admin:SecurePass123!@localhost:5432/medical_devices_db?schema=public
DIRECT_URL=postgresql://medical_admin:SecurePass123!@localhost:5432/medical_devices_db?schema=public

# Redis Cache
REDIS_URL=redis://:RedisPass123!@localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=RedisPass123!

# Elasticsearch (Optional)
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_NODE=http://localhost:9200

# Authentication
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long-change-in-production
SESSION_SECRET=your-session-secret-key-min-32-chars-long-change-in-production
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-key-min-32-chars-long-change-in-production
ENCRYPTION_KEY=your-encryption-key-32-chars-long-change-in-production

# Payment Gateways
# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# PayPal
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# MyFatoorah (Middle East Payment Gateway)
NEXT_PUBLIC_MYFATOORAH_API_KEY=your_myfatoorah_api_key
MYFATOORAH_API_SECRET=your_myfatoorah_api_secret
MYFATOORAH_COUNTRY_ISO=KWT

# Email Service (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM=noreply@medical-devices.com
EMAIL_FROM=Medical Devices <noreply@medical-devices.com>
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your-email@gmail.com
EMAIL_SERVER_PASSWORD=your-app-specific-password

# AWS S3 Storage
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET=medical-devices-uploads

# MinIO (Local S3-compatible storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=MinioPass123!
MINIO_BUCKET=medical-devices

# Cloudinary (Alternative to S3)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Monitoring & Analytics
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=your_sentry_project

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ANALYTICS=G-XXXXXXXXXX

# Google Maps API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# OpenAI API (for AI features)
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_ORG_ID=org-your_openai_org_id

# Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
NOTIFICATION_EMAIL=admin@medical-devices.com

# Socket.io Configuration
SOCKET_IO_SERVER_URL=http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_ENABLED=true

# Cron Jobs
CRON_SECRET=your_cron_secret_key

# Feature Flags
ENABLE_CHAT=true
ENABLE_AI_RECOMMENDATIONS=false
ENABLE_ADVANCED_ANALYTICS=true
ENABLE_MAINTENANCE_MODE=false
ENABLE_DEBUG_MODE=false

# Security
CORS_ORIGIN=http://localhost:3000
CSP_REPORT_URI=https://your-csp-report-endpoint.com

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
ENABLE_REQUEST_LOGGING=true

# Development
NEXT_TELEMETRY_DISABLED=1
ANALYZE=false
BUNDLE_ANALYZE=false

# Testing
TEST_DATABASE_URL=postgresql://test:test@localhost:5432/medical_devices_test?schema=public
CI=false

# Vercel Deployment (Production)
VERCEL_URL=
VERCEL_ENV=development

# Performance
ENABLE_CACHE=true
CACHE_TTL=3600
MAX_UPLOAD_SIZE=10485760

# Internationalization
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,ar

# API Keys for External Services
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Backup Configuration
BACKUP_ENABLED=false
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS=30

# System Defaults
DEFAULT_CURRENCY=USD
DEFAULT_TIMEZONE=UTC
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100