# Minimal configuration for Vercel deployment
# Copy this to .env.local and fill in your values

# Database (Required)
# Use Neon, Supabase, or Railway PostgreSQL
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Authentication (Required - generate secure random strings)
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here

# Application URL (update after deployment)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (Optional - can configure later in admin panel)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Payment (Optional - can configure later in admin panel)
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx