// This is your Prisma schema file,
// Medical Devices Marketplace Database Schema
// Version: 3.0.0

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== USER MANAGEMENT ====================

enum UserType {
  HEALTHCARE_PROVIDER
  EQUIPMENT_SUPPLIER
  MAINTENANCE_ENGINEER
  CUSTOMER_SERVICE
  ADMIN
  INDIVIDUAL_CUSTOMER
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  INACTIVE
}

enum VerificationStatus {
  UNVERIFIED
  EMAIL_VERIFIED
  DOCUMENTS_VERIFIED
  FULLY_VERIFIED
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  passwordHash       String
  firstName          String
  lastName           String
  phoneNumber        String
  userType           UserType
  status             UserStatus         @default(PENDING_VERIFICATION)
  verificationStatus VerificationStatus @default(UNVERIFIED)
  profileImage       String?
  preferredLanguage  String             @default("en")
  twoFactorEnabled   Boolean            @default(false)
  twoFactorSecret    String?
  emailVerifiedAt    DateTime?
  lastLoginAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  // Relations
  healthcareProfile  HealthcareProvider?
  supplierProfile    EquipmentSupplier?
  engineerProfile    MaintenanceEngineer?
  customerServiceProfile CustomerServiceProfile?
  adminProfile       AdminProfile?
  individualProfile  IndividualCustomer?
  
  sessions           Session[]
  auditLogs          AuditLog[]
  orders             Order[]
  rentals            RentalAgreement[]
  maintenanceRequests MaintenanceRequest[]
  chatSessions       ChatParticipant[]
  notifications      Notification[]
  reviews            ProductReview[]
  questions          ProductQuestion[]
  answers            ProductAnswer[]
  wishlist           WishlistItem[]
  cart               Cart?
  supportTickets     SupportTicket[]
  verificationTokens VerificationToken[]
  passwordResets     PasswordReset[]
  uploadedFiles      UploadedFile[]
  couponUsages       CouponUsage[]
  
  @@index([email])
  @@index([userType])
  @@index([status])
}

model HealthcareProvider {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationName    String
  organizationType    String   // Hospital, Clinic, Diagnostic Center, etc.
  licenseNumber       String
  taxRegistrationNumber String?
  numberOfBeds        Int?
  yearEstablished     Int?
  emergencyContact    String?
  website             String?
  
  // JSON fields for complex data
  address             Json     // {street, city, state, country, postalCode}
  specializations     Json     // Array of specializations
  certifications      Json     // Array of certifications
  operatingHours      Json?    // Operating hours by day
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  @@index([organizationName])
}

model EquipmentSupplier {
  id                        String    @id @default(cuid())
  userId                    String    @unique
  user                      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName               String
  businessRegistrationNumber String
  taxId                     String?
  yearEstablished           Int?
  numberOfEmployees         Int?
  annualRevenue             Float?
  website                   String?
  
  // JSON fields
  address                   Json      // {street, city, state, country, postalCode}
  productCategories         Json      // Array of product categories
  certifications            Json      // Array of certifications
  brands                    Json?     // Array of brands represented
  warehouses                Json?     // Array of warehouse locations
  
  verified                  Boolean   @default(false)
  verifiedAt                DateTime?
  rating                    Float     @default(0)
  
  products                  Product[]
  
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  
  @@index([companyName])
  @@index([verified])
}

model MaintenanceEngineer {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  certificationNumber String
  experienceYears     Int
  hourlyRate          Float?
  availability        String   @default("AVAILABLE") // AVAILABLE, BUSY, OFF_DUTY
  
  // JSON fields
  specializations     Json     // Array of equipment types
  certifications      Json     // Array of certifications
  serviceAreas        Json     // Array of service locations
  workSchedule        Json?    // Weekly schedule
  
  rating              Float    @default(0)
  completedJobs       Int      @default(0)
  
  maintenanceJobs     MaintenanceRequest[]
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  @@index([availability])
}

model CustomerServiceProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeId      String   @unique
  department      String
  extensionNumber String?
  shift           String   // MORNING, EVENING, NIGHT
  
  assignedTickets SupportTicket[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AdminProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissions Json     // Array of permission strings
  role        String   // SUPER_ADMIN, ADMIN, MODERATOR
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model IndividualCustomer {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateOfBirth  DateTime?
  gender       String?
  
  // JSON fields
  address      Json      // {street, city, state, country, postalCode}
  preferences  Json?     // Shopping preferences
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ==================== FILE UPLOADS ====================

model UploadedFile {
  id           String   @id @default(cuid())
  fileName     String
  originalName String
  mimeType     String
  size         Int
  path         String
  url          String?
  
  uploadedBy   String?
  userId       String?
  
  // Relations
  productId    String?
  product      Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  // Metadata
  metadata     Json?    // Additional metadata like dimensions for images
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@index([fileName])
  @@index([userId])
  @@index([productId])
}

// ==================== PRODUCT MANAGEMENT ====================

enum ProductCategory {
  DIAGNOSTIC
  SURGICAL
  MONITORING
  THERAPEUTIC
  LABORATORY
  EMERGENCY
  REHABILITATION
  DENTAL
  IMAGING
  OTHER
}

enum ProductCondition {
  NEW
  REFURBISHED
  USED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  OUT_OF_STOCK
  DISCONTINUED
  SUSPENDED
}

model Product {
  id                String           @id @default(cuid())
  supplierId        String
  supplier          EquipmentSupplier @relation(fields: [supplierId], references: [id])
  
  name              String
  nameAr            String
  description       String           @db.Text
  descriptionAr     String           @db.Text
  sku               String           @unique
  barcode           String?
  
  category          ProductCategory
  subcategory       String?
  condition         ProductCondition @default(NEW)
  status            ProductStatus    @default(DRAFT)
  
  price             Float
  compareAtPrice    Float?
  costPrice         Float?
  currency          String           @default("USD")
  
  quantity          Int              @default(0)
  minOrderQuantity  Int              @default(1)
  maxOrderQuantity  Int?
  
  weight            Float?           // in kg
  dimensions        Json?            // {length, width, height}
  
  // JSON fields
  images            Json             // Array of image URLs
  specifications    Json             // Technical specifications
  features          Json?            // Key features array
  certifications    Json?            // Certifications array
  documents         Json?            // Product documents/manuals
  tags              Json?            // Search tags
  
  warrantyPeriod    Int?             // in months
  returnPeriod      Int              @default(30) // in days
  
  isFeatured        Boolean          @default(false)
  isPublished       Boolean          @default(false)
  publishedAt       DateTime?
  
  views             Int              @default(0)
  salesCount        Int              @default(0)
  rating            Float            @default(0)
  
  // Relations
  orderItems        OrderItem[]
  cartItems         CartItem[]
  wishlistItems     WishlistItem[]
  reviews           ProductReview[]
  questions         ProductQuestion[]
  rentalItems       RentalItem[]
  maintenanceHistory MaintenanceRequest[]
  priceHistory      PriceHistory[]
  inventory         InventoryLog[]
  uploadedFiles     UploadedFile[]
  
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  
  @@index([supplierId])
  @@index([category])
  @@index([status])
  @@index([sku])
  @@index([name])
  @@fulltext([name, description])
}

// ==================== ORDER MANAGEMENT ====================

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  PAYPAL
  STRIPE
  MYFATOORAH
  BANK_TRANSFER
  CASH_ON_DELIVERY
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  paymentMethod   PaymentMethod?
  
  subtotal        Float
  tax             Float
  shipping        Float
  discount        Float         @default(0)
  total           Float
  
  currency        String        @default("USD")
  exchangeRate    Float         @default(1)
  
  // JSON fields
  shippingAddress Json          // Address details
  billingAddress  Json          // Address details
  metadata        Json?         // Additional order data
  
  notes           String?       @db.Text
  internalNotes   String?       @db.Text
  
  // Dates
  confirmedAt     DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  
  // Relations
  items           OrderItem[]
  payments        Payment[]
  shipments       Shipment[]
  invoices        Invoice[]
  refunds         Refund[]
  couponUsages    CouponUsage[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@index([paymentStatus])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  
  quantity    Int
  price       Float
  discount    Float    @default(0)
  tax         Float    @default(0)
  total       Float
  
  // JSON fields
  metadata    Json?    // Product snapshot at time of order
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([orderId])
  @@index([productId])
}

// ==================== PAYMENT MANAGEMENT ====================

model Payment {
  id              String        @id @default(cuid())
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id])
  
  amount          Float
  currency        String        @default("USD")
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  
  transactionId   String?       @unique
  gatewayResponse Json?         // Gateway response data
  
  paidAt          DateTime?
  failedAt        DateTime?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([orderId])
  @@index([transactionId])
  @@index([status])
}

model Refund {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  
  amount      Float
  reason      String
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED, COMPLETED
  
  approvedBy  String?
  processedAt DateTime?
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([orderId])
  @@index([status])
}

// ==================== SHIPPING & LOGISTICS ====================

model Shipment {
  id              String   @id @default(cuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id])
  
  carrier         String
  trackingNumber  String?  @unique
  status          String   @default("PREPARING") // PREPARING, SHIPPED, IN_TRANSIT, DELIVERED
  
  estimatedDelivery DateTime?
  actualDelivery  DateTime?
  
  shippingCost    Float
  weight          Float?
  
  // JSON fields
  trackingHistory Json?    // Tracking updates
  documents       Json?    // Shipping documents
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([orderId])
  @@index([trackingNumber])
  @@index([status])
}

// ==================== PROMOTIONS & COUPONS ====================

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
  BUY_X_GET_Y
}

enum CouponStatus {
  ACTIVE
  EXPIRED
  DISABLED
  USED
}

model Coupon {
  id                String       @id @default(cuid())
  code              String       @unique
  description       String?
  type              CouponType
  value             Float        // Percentage (0-100) or fixed amount
  minimumPurchase   Float?       // Minimum order amount required
  maximumDiscount   Float?       // Maximum discount amount for percentage coupons
  
  // Usage limits
  usageLimit        Int?         // Total number of times coupon can be used
  usageCount        Int          @default(0)
  usageLimitPerUser Int?         // Number of times each user can use
  
  // Validity
  validFrom         DateTime     @default(now())
  validUntil        DateTime?
  status            CouponStatus @default(ACTIVE)
  
  // Restrictions
  categories        String[]     // Applicable product categories
  products          String[]     // Specific product IDs
  userTypes         String[]     // Applicable user types
  
  // Metadata
  createdBy         String?
  metadata          Json?        // Additional configuration
  
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  
  // Relations
  usages            CouponUsage[]
  
  @@index([code])
  @@index([status])
  @@index([validFrom, validUntil])
}

model CouponUsage {
  id        String   @id @default(cuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  orderId   String?
  order     Order?   @relation(fields: [orderId], references: [id])
  
  discountAmount Float
  
  usedAt    DateTime @default(now())
  
  @@unique([couponId, userId, orderId])
  @@index([couponId])
  @@index([userId])
  @@index([orderId])
}

// ==================== CART & WISHLIST ====================

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  items     CartItem[]
  
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  
  quantity  Int      @default(1)
  
  addedAt   DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  
  addedAt   DateTime @default(now())
  
  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

// ==================== REVIEWS & RATINGS ====================

model ProductReview {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  
  rating        Int      // 1-5
  title         String
  comment       String   @db.Text
  
  isVerified    Boolean  @default(false) // Verified purchase
  helpful       Int      @default(0)      // Helpful votes count
  
  images        Json?    // Review images
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([productId])
  @@index([userId])
  @@index([rating])
}

model ProductQuestion {
  id        String          @id @default(cuid())
  productId String
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User            @relation(fields: [userId], references: [id])
  
  question  String          @db.Text
  
  answers   ProductAnswer[]
  
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  
  @@index([productId])
  @@index([userId])
}

model ProductAnswer {
  id         String          @id @default(cuid())
  questionId String
  question   ProductQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userId     String
  user       User            @relation(fields: [userId], references: [id])
  
  answer     String          @db.Text
  isOfficial Boolean         @default(false) // Answer from supplier
  helpful    Int             @default(0)
  
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  
  @@index([questionId])
  @@index([userId])
}

// ==================== RENTAL MANAGEMENT ====================

enum RentalStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
  OVERDUE
}

model RentalAgreement {
  id              String       @id @default(cuid())
  agreementNumber String       @unique @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id])
  
  status          RentalStatus @default(DRAFT)
  
  startDate       DateTime
  endDate         DateTime
  actualReturnDate DateTime?
  
  depositAmount   Float
  dailyRate       Float
  totalAmount     Float
  
  // JSON fields
  deliveryAddress Json
  terms           Json         // Rental terms and conditions
  insurance       Json?        // Insurance details
  
  notes           String?      @db.Text
  
  // Relations
  items           RentalItem[]
  payments        RentalPayment[]
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  
  @@index([userId])
  @@index([agreementNumber])
  @@index([status])
}

model RentalItem {
  id          String          @id @default(cuid())
  rentalId    String
  rental      RentalAgreement @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  productId   String
  product     Product         @relation(fields: [productId], references: [id])
  
  quantity    Int
  dailyRate   Float
  
  condition   Json            // Condition at rental and return
  
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  
  @@index([rentalId])
  @@index([productId])
}

model RentalPayment {
  id        String          @id @default(cuid())
  rentalId  String
  rental    RentalAgreement @relation(fields: [rentalId], references: [id])
  
  amount    Float
  type      String          // DEPOSIT, RENTAL, PENALTY, REFUND
  status    PaymentStatus
  
  paidAt    DateTime?
  
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  
  @@index([rentalId])
}

// ==================== MAINTENANCE & SERVICE ====================

enum MaintenanceStatus {
  REQUESTED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model MaintenanceRequest {
  id            String              @id @default(cuid())
  requestNumber String              @unique @default(cuid())
  userId        String
  user          User                @relation(fields: [userId], references: [id])
  engineerId    String?
  engineer      MaintenanceEngineer? @relation(fields: [engineerId], references: [id])
  productId     String?
  product       Product?            @relation(fields: [productId], references: [id])
  
  status        MaintenanceStatus   @default(REQUESTED)
  priority      String              @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  
  issueType     String              // REPAIR, MAINTENANCE, INSPECTION, CALIBRATION
  description   String              @db.Text
  
  scheduledDate DateTime?
  completedDate DateTime?
  
  estimatedCost Float?
  actualCost    Float?
  
  // JSON fields
  location      Json                // Service location
  diagnostics   Json?               // Diagnostic results
  workPerformed Json?               // Work details
  partsUsed     Json?               // Parts and materials
  images        Json?               // Before/after images
  
  rating        Int?                // Service rating
  feedback      String?             @db.Text
  
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  
  @@index([userId])
  @@index([engineerId])
  @@index([status])
  @@index([priority])
}

// ==================== COMMUNICATION ====================

model ChatSession {
  id           String            @id @default(cuid())
  type         String            // SUPPORT, INQUIRY, NEGOTIATION
  status       String            @default("ACTIVE") // ACTIVE, CLOSED, ARCHIVED
  
  participants ChatParticipant[]
  messages     ChatMessage[]
  
  metadata     Json?
  
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  closedAt     DateTime?
  
  @@index([status])
}

model ChatParticipant {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  
  role      String      @default("PARTICIPANT") // PARTICIPANT, MODERATOR
  joinedAt  DateTime    @default(now())
  leftAt    DateTime?
  
  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  senderId  String
  
  content   String      @db.Text
  type      String      @default("TEXT") // TEXT, IMAGE, FILE, SYSTEM
  
  metadata  Json?       // Attachments, etc.
  
  isEdited  Boolean     @default(false)
  isDeleted Boolean     @default(false)
  
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  
  @@index([sessionId])
  @@index([senderId])
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type      String   // ORDER, PAYMENT, SHIPPING, SYSTEM, PROMOTION
  title     String
  message   String   @db.Text
  
  data      Json?    // Additional notification data
  
  isRead    Boolean  @default(false)
  readAt    DateTime?
  
  createdAt DateTime @default(now())
  
  @@index([userId])
  @@index([isRead])
  @@index([type])
}

// ==================== SUPPORT ====================

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model SupportTicket {
  id           String                  @id @default(cuid())
  ticketNumber String                  @unique @default(cuid())
  userId       String
  user         User                    @relation(fields: [userId], references: [id])
  assignedToId String?
  assignedTo   CustomerServiceProfile? @relation(fields: [assignedToId], references: [id])
  
  status       TicketStatus            @default(OPEN)
  priority     TicketPriority          @default(MEDIUM)
  
  category     String                  // TECHNICAL, BILLING, SHIPPING, PRODUCT, OTHER
  subject      String
  description  String                  @db.Text
  
  resolution   String?                 @db.Text
  
  attachments  Json?                   // File attachments
  
  resolvedAt   DateTime?
  closedAt     DateTime?
  
  satisfaction Int?                    // 1-5 rating
  feedback     String?                 @db.Text
  
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  
  @@index([userId])
  @@index([assignedToId])
  @@index([status])
  @@index([priority])
}

// ==================== INVOICING ====================

model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique @default(cuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id])
  
  status        String   @default("DRAFT") // DRAFT, SENT, PAID, OVERDUE, CANCELLED
  
  dueDate       DateTime
  paidAt        DateTime?
  
  subtotal      Float
  tax           Float
  total         Float
  
  // JSON fields
  lineItems     Json     // Invoice line items
  billingInfo   Json     // Billing information
  notes         Json?    // Invoice notes
  
  pdfUrl        String?  // Generated PDF URL
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([orderId])
  @@index([invoiceNumber])
  @@index([status])
}

// ==================== AUDIT & SECURITY ====================

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  token        String   @unique
  ipAddress    String?
  userAgent    String?
  
  lastActivity DateTime @default(now())
  expiresAt    DateTime
  
  createdAt    DateTime @default(now())
  
  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  
  action    String   // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, etc.
  entity    String   // User, Product, Order, etc.
  entityId  String?
  
  oldData   Json?    // Previous state
  newData   Json?    // New state
  
  ipAddress String?
  userAgent String?
  
  createdAt DateTime @default(now())
  
  @@index([userId])
  @@index([entity])
  @@index([action])
  @@index([createdAt])
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  type      String   @default("EMAIL_VERIFICATION")
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  
  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

// ==================== INVENTORY MANAGEMENT ====================

model InventoryLog {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  
  type        String   // IN, OUT, ADJUSTMENT, RETURN
  quantity    Int
  balance     Int      // Balance after transaction
  
  reference   String?  // Order ID, Return ID, etc.
  reason      String?
  
  performedBy String?
  
  createdAt   DateTime @default(now())
  
  @@index([productId])
  @@index([type])
  @@index([createdAt])
}

model PriceHistory {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  
  oldPrice    Float
  newPrice    Float
  
  reason      String?
  changedBy   String?
  
  createdAt   DateTime @default(now())
  
  @@index([productId])
  @@index([createdAt])
}

// ==================== SETTINGS & CONFIGURATION ====================

model SystemSetting {
  id    String @id @default(cuid())
  key   String @unique
  value Json
  type  String // STRING, NUMBER, BOOLEAN, JSON
  
  description String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([key])
}

model EmailTemplate {
  id        String   @id @default(cuid())
  name      String   @unique
  subject   String
  body      String   @db.Text
  variables Json     // Available variables for template
  
  isActive  Boolean  @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([name])
  @@index([isActive])
}