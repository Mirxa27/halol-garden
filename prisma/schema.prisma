generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminProfile {
  id          String   @id
  userId      String   @unique
  permissions Json
  role        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldData   Json?
  newData   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  User      User?    @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([createdAt])
  @@index([entity])
  @@index([userId])
}

model Cart {
  id        String     @id
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime
  User      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  CartItem  CartItem[]
}

model CartItem {
  id        String   @id
  cartId    String
  productId String
  quantity  Int      @default(1)
  addedAt   DateTime @default(now())
  updatedAt DateTime
  Cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  Product   Product  @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
}

model ChatMessage {
  id          String      @id
  sessionId   String
  senderId    String
  content     String
  type        String      @default("TEXT")
  metadata    Json?
  isEdited    Boolean     @default(false)
  isDeleted   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime
  ChatSession ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([sessionId])
}

model ChatParticipant {
  id          String      @id
  sessionId   String
  userId      String
  role        String      @default("PARTICIPANT")
  joinedAt    DateTime    @default(now())
  leftAt      DateTime?
  ChatSession ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  User        User        @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
}

model ChatSession {
  id              String            @id
  type            String
  status          String            @default("ACTIVE")
  metadata        Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  closedAt        DateTime?
  ChatMessage     ChatMessage[]
  ChatParticipant ChatParticipant[]

  @@index([status])
}

model CustomerServiceProfile {
  id              String          @id
  userId          String          @unique
  employeeId      String          @unique
  department      String
  extensionNumber String?
  shift           String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  User            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  SupportTicket   SupportTicket[]
}

model EmailTemplate {
  id        String   @id
  name      String   @unique
  subject   String
  body      String
  variables Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime

  @@index([isActive])
  @@index([name])
}

model EquipmentSupplier {
  id                         String    @id
  userId                     String    @unique
  companyName                String
  businessRegistrationNumber String
  taxId                      String?
  yearEstablished            Int?
  numberOfEmployees          Int?
  annualRevenue              Float?
  website                    String?
  address                    Json
  productCategories          Json
  certifications             Json
  brands                     Json?
  warehouses                 Json?
  deliveryCapabilities       Json?
  returnPolicy               Json?
  warrantyTerms              Json?
  verified                   Boolean   @default(false)
  verifiedAt                 DateTime?
  rating                     Float     @default(0)
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime
  User                       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  Product                    Product[]

  @@index([companyName])
  @@index([verified])
}

model HealthcareProvider {
  id                    String   @id
  userId                String   @unique
  organizationName      String
  organizationType      String
  licenseNumber         String
  taxRegistrationNumber String?
  numberOfBeds          Int?
  yearEstablished       Int?
  emergencyContact      String?
  website               String?
  address               Json
  specializations       Json
  certifications        Json
  operatingHours        Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime
  User                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationName])
}

model IndividualCustomer {
  id          String    @id
  userId      String    @unique
  dateOfBirth DateTime?
  gender      String?
  address     Json
  preferences Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  User        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InventoryLog {
  id          String   @id
  productId   String
  type        String
  quantity    Int
  balance     Int?
  reference   String?
  reason      String?
  metadata    Json?
  performedBy String?
  createdAt   DateTime @default(now())
  Product     Product  @relation(fields: [productId], references: [id])

  @@index([createdAt])
  @@index([productId])
  @@index([type])
}

model Invoice {
  id            String    @id
  invoiceNumber String    @unique
  orderId       String
  status        String    @default("DRAFT")
  dueDate       DateTime
  paidAt        DateTime?
  subtotal      Float
  tax           Float
  total         Float
  lineItems     Json
  billingInfo   Json
  notes         Json?
  pdfUrl        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  Order         Order     @relation(fields: [orderId], references: [id])

  @@index([invoiceNumber])
  @@index([orderId])
  @@index([status])
}

model MaintenanceEngineer {
  id                  String               @id
  userId              String               @unique
  certificationNumber String
  experienceYears     Int
  hourlyRate          Float?
  availability        String               @default("AVAILABLE")
  specializations     Json
  certifications      Json
  serviceAreas        Json
  workSchedule        Json?
  rating              Float                @default(0)
  completedJobs       Int                  @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime
  User                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  MaintenanceRequest  MaintenanceRequest[]

  @@index([availability])
}

model MaintenanceRequest {
  id                  String               @id
  requestNumber       String               @unique
  userId              String
  engineerId          String?
  productId           String?
  status              MaintenanceStatus    @default(REQUESTED)
  priority            String               @default("NORMAL")
  issueType           String
  description         String
  scheduledDate       DateTime?
  completedDate       DateTime?
  estimatedCost       Float?
  actualCost          Float?
  location            Json
  diagnostics         Json?
  workPerformed       Json?
  partsUsed           Json?
  images              Json?
  rating              Int?
  feedback            String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime
  MaintenanceEngineer MaintenanceEngineer? @relation(fields: [engineerId], references: [id])
  Product             Product?             @relation(fields: [productId], references: [id])
  User                User                 @relation(fields: [userId], references: [id])

  @@index([engineerId])
  @@index([priority])
  @@index([status])
  @@index([userId])
}

model Notification {
  id        String    @id
  userId    String
  type      String
  title     String
  message   String
  data      Json?
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())
  User      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isRead])
  @@index([type])
  @@index([userId])
}

model Order {
  id              String         @id
  orderNumber     String         @unique
  userId          String
  status          OrderStatus    @default(PENDING)
  paymentStatus   PaymentStatus  @default(PENDING)
  paymentMethod   PaymentMethod?
  subtotal        Float
  tax             Float
  shipping        Float
  discount        Float          @default(0)
  total           Float
  currency        String         @default("USD")
  exchangeRate    Float          @default(1)
  shippingAddress Json
  billingAddress  Json
  metadata        Json?
  notes           String?
  internalNotes   String?
  confirmedAt     DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime
  Invoice         Invoice[]
  User            User           @relation(fields: [userId], references: [id])
  OrderItem       OrderItem[]
  Payment         Payment[]
  Refund          Refund[]
  Shipment        Shipment[]
  Shipping        Shipping?

  @@index([orderNumber])
  @@index([paymentStatus])
  @@index([status])
  @@index([userId])
}

model OrderItem {
  id        String   @id
  orderId   String
  productId String
  quantity  Int
  price     Float
  discount  Float    @default(0)
  tax       Float    @default(0)
  total     Float
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime
  Order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  Product   Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model PasswordReset {
  id        String    @id
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  User      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([token])
  @@index([userId])
}

model Payment {
  id              String        @id
  orderId         String
  amount          Float
  currency        String        @default("USD")
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  transactionId   String?       @unique
  gatewayResponse Json?
  paidAt          DateTime?
  failedAt        DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime
  Order           Order         @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
  @@index([transactionId])
}

model PriceHistory {
  id        String   @id
  productId String
  oldPrice  Float
  newPrice  Float
  reason    String?
  changedBy String?
  createdAt DateTime @default(now())
  Product   Product  @relation(fields: [productId], references: [id])

  @@index([createdAt])
  @@index([productId])
}

model Product {
  id                  String               @id
  supplierId          String
  name                String
  nameAr              String
  description         String
  descriptionAr       String
  sku                 String               @unique
  barcode             String?
  category            ProductCategory
  subcategory         String?
  brand               String?
  model               String?
  manufacturerCountry String?
  condition           ProductCondition     @default(NEW)
  status              ProductStatus        @default(DRAFT)
  availabilityType    AvailabilityType     @default(SALE)
  price               Float
  compareAtPrice      Float?
  costPrice           Float?
  currency            String               @default("USD")
  quantity            Int                  @default(0)
  minOrderQuantity    Int                  @default(1)
  maxOrderQuantity    Int?
  weight              Float?
  dimensions          Json?
  images              Json
  specifications      Json
  features            Json?
  certifications      Json?
  documents           Json?
  tags                Json?
  warranty            Json?
  warrantyPeriod      Int?
  returnPeriod        Int                  @default(30)
  featured            Boolean              @default(false)
  isFeatured          Boolean              @default(false)
  isPublished         Boolean              @default(false)
  publishedAt         DateTime?
  views               Int                  @default(0)
  salesCount          Int                  @default(0)
  rating              Float                @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime
  CartItem            CartItem[]
  InventoryLog        InventoryLog[]
  MaintenanceRequest  MaintenanceRequest[]
  OrderItem           OrderItem[]
  PriceHistory        PriceHistory[]
  EquipmentSupplier   EquipmentSupplier    @relation(fields: [supplierId], references: [id])
  ProductQuestion     ProductQuestion[]
  ProductReview       ProductReview[]
  RentalDetails       RentalDetails?
  RentalItem          RentalItem[]
  SalesDetails        SalesDetails?
  UploadedFile        UploadedFile[]
  WishlistItem        WishlistItem[]

  @@index([category])
  @@index([name])
  @@index([sku])
  @@index([status])
  @@index([supplierId])
}

model ProductAnswer {
  id              String          @id
  questionId      String
  userId          String
  answer          String
  isOfficial      Boolean         @default(false)
  helpful         Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  ProductQuestion ProductQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  User            User            @relation(fields: [userId], references: [id])

  @@index([questionId])
  @@index([userId])
}

model ProductQuestion {
  id            String          @id
  productId     String
  userId        String
  question      String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  ProductAnswer ProductAnswer[]
  Product       Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  User          User            @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([userId])
}

model ProductReview {
  id         String   @id
  productId  String
  userId     String
  rating     Int
  title      String
  comment    String
  isVerified Boolean  @default(false)
  helpful    Int      @default(0)
  images     Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  Product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  User       User     @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([rating])
  @@index([userId])
}

model Refund {
  id          String    @id
  orderId     String
  amount      Float
  reason      String
  status      String    @default("PENDING")
  approvedBy  String?
  processedAt DateTime?
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  Order       Order     @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
}

model RentalAgreement {
  id               String          @id
  agreementNumber  String          @unique
  userId           String
  status           RentalStatus    @default(DRAFT)
  startDate        DateTime
  endDate          DateTime
  actualReturnDate DateTime?
  depositAmount    Float
  dailyRate        Float
  totalAmount      Float
  deliveryAddress  Json
  terms            Json
  insurance        Json?
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime
  User             User            @relation(fields: [userId], references: [id])
  RentalItem       RentalItem[]
  RentalPayment    RentalPayment[]

  @@index([agreementNumber])
  @@index([status])
  @@index([userId])
}

model RentalDetails {
  id                  String       @id
  productId           String       @unique
  dailyRate           Float
  weeklyRate          Float?
  monthlyRate         Float?
  securityDeposit     Float
  minimumRentalPeriod Int          @default(1)
  maximumRentalPeriod Int?
  isAvailable         Boolean      @default(true)
  inventory           Json?
  rentalTerms         Json?
  maintenanceSchedule Json?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime
  Product             Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  RentalUnit          RentalUnit[]

  @@index([productId])
}

model RentalItem {
  id              String          @id
  rentalId        String
  productId       String
  quantity        Int
  dailyRate       Float
  condition       Json
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  Product         Product         @relation(fields: [productId], references: [id])
  RentalAgreement RentalAgreement @relation(fields: [rentalId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([rentalId])
}

model RentalPayment {
  id              String          @id
  rentalId        String
  amount          Float
  type            String
  status          PaymentStatus
  paidAt          DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  RentalAgreement RentalAgreement @relation(fields: [rentalId], references: [id])

  @@index([rentalId])
}

model RentalUnit {
  id              String           @id
  rentalDetailsId String
  serialNumber    String?
  condition       Json?
  status          RentalUnitStatus @default(AVAILABLE)
  location        Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime
  RentalDetails   RentalDetails    @relation(fields: [rentalDetailsId], references: [id], onDelete: Cascade)

  @@index([rentalDetailsId])
  @@index([status])
}

model SalesDetails {
  id               String   @id
  productId        String   @unique
  basePrice        Float
  discountedPrice  Float?
  costPrice        Float?
  minOrderQuantity Int      @default(1)
  maxOrderQuantity Int?
  inventory        Json?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime
  Product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Session {
  id           String   @id
  userId       String
  token        String   @unique
  ipAddress    String?
  userAgent    String?
  lastActivity DateTime @default(now())
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([token])
  @@index([userId])
}

model Shipment {
  id                String    @id
  orderId           String
  carrier           String
  trackingNumber    String?   @unique
  status            String    @default("PREPARING")
  estimatedDelivery DateTime?
  actualDelivery    DateTime?
  shippingCost      Float
  weight            Float?
  trackingHistory   Json?
  documents         Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime
  Order             Order     @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
  @@index([trackingNumber])
}

model Shipping {
  id                String         @id
  orderId           String         @unique
  carrier           String?
  trackingNumber    String?
  status            ShippingStatus @default(PENDING)
  shippingCost      Float          @default(0)
  estimatedDelivery DateTime?
  actualDelivery    DateTime?
  address           Json
  notes             String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime
  Order             Order          @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([trackingNumber])
}

model SupportTicket {
  id                     String                  @id
  ticketNumber           String                  @unique
  userId                 String
  assignedToId           String?
  status                 TicketStatus            @default(OPEN)
  priority               TicketPriority          @default(MEDIUM)
  category               String
  subject                String
  description            String
  resolution             String?
  attachments            Json?
  resolvedAt             DateTime?
  closedAt               DateTime?
  satisfaction           Int?
  feedback               String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime
  CustomerServiceProfile CustomerServiceProfile? @relation(fields: [assignedToId], references: [id])
  User                   User                    @relation(fields: [userId], references: [id])

  @@index([assignedToId])
  @@index([priority])
  @@index([status])
  @@index([userId])
}

model SystemSetting {
  id          String   @id
  key         String   @unique
  value       Json
  type        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@index([key])
}

model UploadedFile {
  id           String   @id
  fileName     String
  originalName String
  mimeType     String
  size         Int
  path         String
  url          String?
  uploadedBy   String?
  userId       String?
  productId    String?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime
  Product      Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  User         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([fileName])
  @@index([productId])
  @@index([userId])
}

model User {
  id                     String                  @id
  email                  String                  @unique
  passwordHash           String
  firstName              String
  lastName               String
  phoneNumber            String
  userType               UserType
  status                 UserStatus              @default(PENDING_VERIFICATION)
  verificationStatus     VerificationStatus      @default(UNVERIFIED)
  profileImage           String?
  preferredLanguage      String                  @default("en")
  twoFactorEnabled       Boolean                 @default(false)
  twoFactorSecret        String?
  emailVerifiedAt        DateTime?
  lastLoginAt            DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime
  backupCodes            Json?
  AdminProfile           AdminProfile?
  AuditLog               AuditLog[]
  Cart                   Cart?
  ChatParticipant        ChatParticipant[]
  CustomerServiceProfile CustomerServiceProfile?
  EquipmentSupplier      EquipmentSupplier?
  HealthcareProvider     HealthcareProvider?
  IndividualCustomer     IndividualCustomer?
  MaintenanceEngineer    MaintenanceEngineer?
  MaintenanceRequest     MaintenanceRequest[]
  Notification           Notification[]
  Order                  Order[]
  PasswordReset          PasswordReset[]
  ProductAnswer          ProductAnswer[]
  ProductQuestion        ProductQuestion[]
  ProductReview          ProductReview[]
  RentalAgreement        RentalAgreement[]
  Session                Session[]
  SupportTicket          SupportTicket[]
  UploadedFile           UploadedFile[]
  VerificationToken      VerificationToken[]
  WishlistItem           WishlistItem[]

  @@index([email])
  @@index([status])
  @@index([userType])
}

model VerificationToken {
  id        String   @id
  userId    String
  token     String   @unique
  type      String   @default("EMAIL_VERIFICATION")
  expiresAt DateTime
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([token])
  @@index([userId])
}

model WishlistItem {
  id        String   @id
  userId    String
  productId String
  addedAt   DateTime @default(now())
  Product   Product  @relation(fields: [productId], references: [id])
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@index([userId])
}

enum AvailabilityType {
  SALE
  RENT
  BOTH
}

enum MaintenanceStatus {
  REQUESTED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  PAYPAL
  STRIPE
  MYFATOORAH
  BANK_TRANSFER
  CASH_ON_DELIVERY
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum ProductCategory {
  DIAGNOSTIC
  SURGICAL
  MONITORING
  THERAPEUTIC
  LABORATORY
  EMERGENCY
  REHABILITATION
  DENTAL
  IMAGING
  OTHER
}

enum ProductCondition {
  NEW
  REFURBISHED
  USED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  OUT_OF_STOCK
  DISCONTINUED
  SUSPENDED
  PENDING_APPROVAL
}

enum RentalStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
  OVERDUE
}

enum RentalUnitStatus {
  AVAILABLE
  RENTED
  MAINTENANCE
  RETIRED
}

enum ShippingStatus {
  PENDING
  PROCESSING
  SHIPPED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  INACTIVE
}

enum UserType {
  HEALTHCARE_PROVIDER
  EQUIPMENT_SUPPLIER
  MAINTENANCE_ENGINEER
  CUSTOMER_SERVICE
  ADMIN
  INDIVIDUAL_CUSTOMER
}

enum VerificationStatus {
  UNVERIFIED
  EMAIL_VERIFIED
  DOCUMENTS_VERIFIED
  FULLY_VERIFIED
}
