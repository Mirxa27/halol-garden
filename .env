# ====================================
# Medical Devices Marketplace
# Production Environment Configuration
# ====================================

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_WS_URL=ws://localhost:3000
NEXT_PUBLIC_SITE_NAME=Medical Devices Marketplace
NEXT_PUBLIC_SUPPORT_EMAIL=support@medical-devices.com

# Database (Use Railway/Neon for production)
DATABASE_URL=postgresql://postgres:password@localhost:5432/medical_marketplace?schema=public
DIRECT_URL=postgresql://postgres:password@localhost:5432/medical_marketplace?schema=public

# Authentication
JWT_SECRET=medical-devices-super-secret-jwt-key-2024-production-ready-32-chars
SESSION_SECRET=medical-devices-session-secret-key-2024-production-ready-32-chars
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=medical-devices-nextauth-secret-2024-production-ready-32-chars
ENCRYPTION_KEY=medical-devices-encryption-key-32-chars-production-ready-secure

# Payment Gateways
# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_51234567890abcdefghijklmnopqrstuvwxyz
STRIPE_SECRET_KEY=sk_test_51234567890abcdefghijklmnopqrstuvwxyz1234567890
STRIPE_WEBHOOK_SECRET=whsec_1234567890abcdefghijklmnopqrstuvwxyz

# PayPal
NEXT_PUBLIC_PAYPAL_CLIENT_ID=AQ1234567890abcdefghijklmnopqrstuvwxyz
PAYPAL_CLIENT_SECRET=EL1234567890abcdefghijklmnopqrstuvwxyz

# MyFatoorah (Middle East Payment Gateway)
NEXT_PUBLIC_MYFATOORAH_API_KEY=test_myfatoorah_api_key_12345
MYFATOORAH_API_SECRET=test_myfatoorah_secret_12345
MYFATOORAH_COUNTRY_ISO=KWT

# Email Service (Using Gmail SMTP for development)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=medical.devices.marketplace@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM=medical.devices.marketplace@gmail.com
EMAIL_FROM=Medical Devices Marketplace <noreply@medical-devices.com>
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=medical.devices.marketplace@gmail.com
EMAIL_SERVER_PASSWORD=your-app-specific-password

# File Storage (Cloudinary for simplicity)
CLOUDINARY_CLOUD_NAME=medical-devices-marketplace
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=abcdefghijklmnopqrstuvwxyz1234567890

# Redis Cache (Railway/Upstash for production)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# OpenAI API (for AI features)
OPENAI_API_KEY=sk-1234567890abcdefghijklmnopqrstuvwxyz1234567890abcdefghijklmn
OPENAI_ORG_ID=org-1234567890abcdefghijklmn

# Google Maps API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyABCDEFGHIJKLMNOPQRSTUVWXYZ1234567

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_ENABLED=true

# Feature Flags
ENABLE_CHAT=true
ENABLE_AI_RECOMMENDATIONS=true
ENABLE_ADVANCED_ANALYTICS=true
ENABLE_MAINTENANCE_MODE=false
ENABLE_DEBUG_MODE=false

# Security
CORS_ORIGIN=http://localhost:3000
CSP_REPORT_URI=https://medical-devices-marketplace.vercel.app/api/csp-report

# System Defaults
DEFAULT_CURRENCY=USD
DEFAULT_TIMEZONE=UTC
DEFAULT_PAGE_SIZE=20
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,ar

# Super Admin Configuration
SUPER_ADMIN_EMAIL=admin@medical-devices.com
SUPER_ADMIN_PASSWORD=SuperAdmin123!@#
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Administrator

# Cron Jobs
CRON_SECRET=medical-devices-cron-secret-2024-production-ready

# Performance
ENABLE_CACHE=true
CACHE_TTL=3600
MAX_UPLOAD_SIZE=10485760

# Development
NEXT_TELEMETRY_DISABLED=1
ANALYZE=false
BUNDLE_ANALYZE=false