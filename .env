# Database Configuration
DATABASE_URL="postgresql://postgres:password@localhost:5432/medical_marketplace?schema=public"

# Redis Configuration
REDIS_URL="redis://localhost:6379"

# JWT Secrets
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"

# Email Configuration
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="your-email@gmail.com"
EMAIL_PASSWORD="your-email-password"
EMAIL_FROM="Medical Marketplace <noreply@medicalmarketplace.com>"

# Payment Gateways
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"
PAYPAL_MODE="sandbox"

MYFATOORAH_API_KEY="your-myfatoorah-api-key"
MYFATOORAH_BASE_URL="https://apitest.myfatoorah.com"
MYFATOORAH_MODE="test"

# File Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760

# AI Configuration
OPENAI_API_KEY="your-openai-api-key"
AI_MODEL="gpt-4"

# Application Settings
NODE_ENV="development"
PORT=3000
CLIENT_URL="http://localhost:5173"
API_URL="http://localhost:3000"

# Session Configuration
SESSION_SECRET="your-session-secret-change-this-in-production"
SESSION_EXPIRY="7d"
REFRESH_TOKEN_EXPIRY="30d"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Encryption
ENCRYPTION_KEY="your-32-character-encryption-key"